class Solution {
public:
    int overlapInt(vector<vector<int>>& arr) {

        map<int,int> mp;

        for(auto &it : arr){
            mp[it[0]]++;
            mp[it[1] + 1]--;
        }

        int cur = 0, ans = 0;

        for(auto &it : mp){
            cur += it.second;
            ans = max(ans, cur);
        }

        return ans;
    }
};
