class Solution {
public:
    int distinctSubseq(string str) {
        const int MOD = 1e9 + 7;
        int n = str.size();

        vector<long long> dp(n+1);
        vector<int> last(26, -1);

        dp[0] = 1;

        for(int i = 1; i <= n; i++){
            dp[i] = (2 * dp[i-1]) % MOD;

            if(last[str[i-1] - 'a'] != -1)
                dp[i] = (dp[i] - dp[last[str[i-1] - 'a'] - 1] + MOD) % MOD;

            last[str[i-1] - 'a'] = i;
        }

        return dp[n];
    }
};
