class Solution{
public:
    long long countBits(int N, long long A[]){
        const long long MOD = 1000000007;
        long long ans = 0;

        for(int bit = 0; bit < 32; bit++){
            long long count1 = 0;

            for(int i = 0; i < N; i++){
                if(A[i] & (1LL << bit)) count1++;
            }

            long long count0 = N - count1;

            ans = (ans + (count1 * count0 % MOD) * 2 % MOD) % MOD;
        }

        return ans;
    }
};
