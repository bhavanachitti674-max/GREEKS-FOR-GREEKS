class Solution {
public:
    Node* prev = NULL;
    Node* head = NULL;

    void inorder(Node* root){
        if(!root) return;

        inorder(root->left);

        if(prev == NULL)
            head = root;
        else{
            root->left = prev;
            prev->right = root;
        }
        prev = root;

        inorder(root->right);
    }

    Node* bToDLL(Node* root) {
        inorder(root);
        return head;
    }
};
