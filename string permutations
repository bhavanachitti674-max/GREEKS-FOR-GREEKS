class Solution {
public:
    void solve(string &s, int idx, vector<string> &ans){
        if(idx == s.size()){
            ans.push_back(s);
            return;
        }

        for(int i = idx; i < s.size(); i++){
            swap(s[idx], s[i]);
            solve(s, idx + 1, ans);
            swap(s[idx], s[i]);
        }
    }

    vector<string> permutation(string S){
        vector<string> ans;
        solve(S, 0, ans);
        sort(ans.begin(), ans.end());
        return ans;
    }
};
