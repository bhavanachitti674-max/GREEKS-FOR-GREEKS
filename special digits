#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    long long mod = 1000000007;

    bool check(long long x, int c, int d){
        while(x){
            int r = x % 10;
            if(r == c || r == d) return true;
            x /= 10;
        }
        return false;
    }

    long long power(long long a,long long b){
        long long res = 1;
        while(b){
            if(b&1) res = (res*a)%mod;
            a = (a*a)%mod;
            b >>= 1;
        }
        return res;
    }

    int bestNumbers(int N,int A,int B,int C,int D){

        if(A == B){
            long long sum = 1LL * N * A;
            if(check(sum,C,D)) return 1;
            return 0;
        }

        vector<long long> fact(N+1), inv(N+1);

        fact[0] = 1;
        for(int i=1;i<=N;i++)
            fact[i] = (fact[i-1]*i)%mod;

        inv[N] = power(fact[N],mod-2);
        for(int i=N-1;i>=0;i--)
            inv[i] = (inv[i+1]*(i+1))%mod;

        long long ans = 0;

        for(int i=0;i<=N;i++){
            long long sum = 1LL*i*A + 1LL*(N-i)*B;

            if(check(sum,C,D)){
                long long comb = fact[N];
                comb = (comb*inv[i])%mod;
                comb = (comb*inv[N-i])%mod;
                ans = (ans + comb)%mod;
            }
        }

        return ans;
    }
};
