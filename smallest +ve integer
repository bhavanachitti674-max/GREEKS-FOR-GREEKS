class Solution{
public:
    long long smallestpositive(vector<long long> array, int n) {
        
        sort(array.begin(), array.end());
        
        long long res = 1;
        
        for(int i = 0; i < n; i++){
            if(array[i] > res)
                break;
            res += array[i];
        }
        
        return res;
    }
};
