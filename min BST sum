class Solution {
public:
    int ans;
    
    struct Info {
        bool isBST;
        int sum, size;
        int minVal, maxVal;
    };
    
    Info solve(Node* root, int target) {
        if (!root) return {true, 0, 0, INT_MAX, INT_MIN};
        
        Info left = solve(root->left, target);
        Info right = solve(root->right, target);
        
        Info curr;
        
        if (left.isBST && right.isBST &&
            root->data > left.maxVal && root->data < right.minVal) {
            
            curr.isBST = true;
            curr.sum = left.sum + right.sum + root->data;
            curr.size = left.size + right.size + 1;
            curr.minVal = min(root->data, left.minVal);
            curr.maxVal = max(root->data, right.maxVal);
            
            if (curr.sum == target)
                ans = min(ans, curr.size);
        } else {
            curr.isBST = false;
            curr.sum = 0;
            curr.size = 0;
            curr.minVal = INT_MIN;
            curr.maxVal = INT_MAX;
        }
        
        return curr;
    }
    
    int minSubtreeSumBST(int target, Node* root) {
        ans = INT_MAX;
        solve(root, target);
        return ans == INT_MAX ? -1 : ans;
    }
};
